# ============================================
# Hermes Agent - Test Image
# Pure Hermes + skill-mcp plugin. No test logic.
# Build: docker build -f Dockerfile.test -t hermes-test .
# ============================================
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright \
    PYTHONPATH=/opt/hermes/plugins/skill-mcp \
    NODE_ENV=production

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git ripgrep ffmpeg gcc \
    python3-dev libffi-dev procps openssh-client \
    nodejs npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/hermes

# Install hermes-agent
RUN pip install --no-cache-dir "hermes-agent[all,messaging]"

# Install test dependencies
RUN pip install --no-cache-dir pytest pytest-asyncio pyyaml

# Hermes config directories
RUN mkdir -p /opt/data/skills /opt/data/logs /root/.hermes

# Copy plugin source into Hermes plugin dir
RUN mkdir -p /opt/hermes/plugins/skill-mcp
COPY *.py /opt/hermes/plugins/skill-mcp/
COPY plugin.yaml /opt/hermes/plugins/skill-mcp/

# Copy test fixtures
COPY fixtures/magic_server.py /opt/data/magic_server.py
COPY fixtures/secret_skill /opt/data/skills/secret-skill
COPY fixtures/test_config.yaml /opt/data/config.yaml
RUN chmod +x /opt/data/magic_server.py

# Copy test runner
COPY tests /opt/hermes/tests

WORKDIR /opt/hermes
CMD ["pytest", "tests/", "-v"]
